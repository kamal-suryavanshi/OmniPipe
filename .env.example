# OmniPipe Docker Environment Variables
# Rename this file to .env and fill in your values before running docker compose.
# NEVER commit .env to git — it is already in .gitignore.

# ── Shared secret (must match the key in scripts/generate_license.py) ─────────
OMNIPIPE_SECRET_KEY=CHANGE_ME_LONG_RANDOM_STRING_HERE

# ── Admin key for /admin/* license server routes ──────────────────────────────
OMNIPIPE_ADMIN_KEY=CHANGE_ME_ADMIN_KEY

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# ── Kitsu ─────────────────────────────────────────────────────────────────────
KITSU_SECRET_KEY=CHANGE_ME_KITSU_SECRET

# ── NAS (for Docker volume mount) ─────────────────────────────────────────────
NAS_HOST=192.168.1.100          # IP of your NAS
NAS_SHARE_PATH=/volume1/projects  # NFS export path on the NAS
